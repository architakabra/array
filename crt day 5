ques: leetcode 160 intersection of two linked lists
ans:
/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    ListNode *getIntersectionNode(ListNode *headA, ListNode *headB) {
        while(headA != NULL)
        {
            ListNode* temp = headB;
            while(temp)
            {
                if(headA==temp)
                {
                    return temp;
                }
                temp = temp->next;
            }
            headA = headA ->next;
        }
        return NULL;
    }
};
