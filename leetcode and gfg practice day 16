ques: rat in maze gfg practice 
ans:
class Solution {
public:
    void solve(int x, int y, vector<vector<int>> &maze, int n,
               vector<string> &ans, string path,
               vector<vector<int>> &visited) {

        if (x == n - 1 && y == n - 1) {
            ans.push_back(path);
            return;
        }

        visited[x][y] = 1;

        // Down
        if (x + 1 < n && maze[x + 1][y] == 1 &&
            !visited[x + 1][y]) {
            solve(x + 1, y, maze, n, ans, path + 'D', visited);
        }

        // Left
        if (y - 1 >= 0 && maze[x][y - 1] == 1 &&
            !visited[x][y - 1]) {
            solve(x, y - 1, maze, n, ans, path + 'L', visited);
        }

        // Right
        if (y + 1 < n && maze[x][y + 1] == 1 &&
            !visited[x][y + 1]) {
            solve(x, y + 1, maze, n, ans, path + 'R', visited);
        }

        // Up
        if (x - 1 >= 0 && maze[x - 1][y] == 1 &&
            !visited[x - 1][y]) {
            solve(x - 1, y, maze, n, ans, path + 'U', visited);
        }

        visited[x][y] = 0; // Backtrack
    }

    vector<string> ratInMaze(vector<vector<int>> &maze) {
    int n = maze.size();

    vector<string> ans;

    if (maze[0][0] == 0 || maze[n - 1][n - 1] == 0)
        return ans;

    vector<vector<int>> visited(n, vector<int>(n, 0));

    solve(0, 0, maze, n, ans, "", visited);

    return ans;
}
};
