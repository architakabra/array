ques: Tower of Hanoi (gfg)
ans:
class Solution {
public:
    long long towerOfHanoi(int n, int from, int to, int aux) {
        if (n == 0)
            return 0;

        return towerOfHanoi(n - 1, from, aux, to)
             + 1
             + towerOfHanoi(n - 1, aux, to, from);
    }
};
