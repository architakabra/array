ques: leetcode 50 Pow(x,n)
ans:
class Solution {
public:
    double myPow(double x, int n) {
        long long N = n;  // Handle INT_MIN

        if (N < 0) {
            x = 1 / x;
            N = -N;
        }

        double ans = 1;

        while (N > 0) {
            if (N % 2 == 1) {
                ans *= x;
            }

            x *= x;
            N /= 2;
        }

        return ans;
    }
};
