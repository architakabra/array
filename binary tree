class Solution {
    void solve(TreeNode* root, vector<int>& arr)
    {
        // base case
        if(root == NULL)
        {
            return;
        }

        arr.push_back(root->val);  // Root
        solve(root->left, arr);    // Left
        solve(root->right, arr);   // Right
    }

public:
    vector<int> preorderTraversal(TreeNode* root) {
        vector<int> arr;

        solve(root, arr);

        return arr;
    }
};
