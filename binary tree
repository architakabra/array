class Solution {
    void solve(TreeNode* root, vector<int>& arr)
    {
        // base case
        if(root == NULL)
        {
            return;
        }

        solve(root->left, arr);    // Left
        solve(root->right, arr);   // Right
        arr.push_back(root->val);  // Root
    }

public:
    vector<int> postorderTraversal(TreeNode* root) {
        vector<int> arr;

        solve(root, arr);

        return arr;
    }
};
