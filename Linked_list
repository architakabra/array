ques: to insert and print the length of the linked list
ans:
#include <iostream>
using namespace std;

class Node
{
public:
    int v;
    Node* next;
  // constructor
    Node(int val)
    {
        v = val;
        next = NULL;
    }
};

// Insert at start
void insertAtStart(Node* &head, Node* &tail, int val)
{
    // Linked list is empty
    if(head == NULL)
    {
        Node* n = new Node(val);
        head = tail = n;
    }
    else
    {
        Node* n = new Node(val);
        n->next = head;
        head = n;
    }
}

// Function to find length of linked list
int LengthLL(Node* head)
{
    int count = 0;

    while(head != NULL)
    {
        count++;
        head = head->next;
    }

    return count;
}

// Function to print linked list
void printLL(Node* head)
{
    while(head != NULL)
    {
        cout << head->v << " ";
        head = head->next;
    }
    cout << endl;
}

int main()
{
    Node* head = NULL;
    Node* tail = NULL;

    insertAtStart(head, tail, 1);
    insertAtStart(head, tail, 2);
    insertAtStart(head, tail, 3);

    cout << "Linked List: ";
    printLL(head);

    cout << "Length of Linked List: " << LengthLL(head);

    return 0;
}
