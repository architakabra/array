ques: middle of the linked list (Floyd's Cycle Algorithm)
ans:
class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        // if linked list is empty or only have 1 node
        if (head == NULL || head -> next == NULL)
        {
            return head;
        }
        // if LL has only 2 node
        if(head -> next -> next == NULL)
        {
            return head -> next;
        }
        ListNode*slow = head;
        ListNode*fast = head;
        while(fast != NULL && fast -> next != NULL)
        {
            slow = slow -> next;
            fast = fast -> next -> next;
        }
        return slow;
    }
};
