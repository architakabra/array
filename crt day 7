ques: leetcode 215 kth largest element in an array
ans:
((priority queue (heap))when we have to find children in binary tree left = 2*I and right = 2*i+1 and parent = (I/2) (heap is always in complete binary tree)

class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        priority_queue<int>pq;
        for(int i = 0; i<nums.size(); i++)
        {
            pq.push(nums[i]);
        }
        int ans = 0;
        while(!pq.empty()&&k--)
        {
            ans=pq.top();
            pq.pop();
        }
        return ans;
    }
};
