ques: leetcode 378 kth smallest element in a sorted matrix
ans: (using min heap)
class Solution {
public:
    int kthSmallest(vector<vector<int>>& matrix, int k) {
        priority_queue<int,vector<int>,greater<int>>p;
        int n = matrix.size();
        int m = matrix[0].size();

        for(int i = 0; i<n; i++)
        {
            for(int j = 0; j<m; j++)
            {
               p.push(matrix[i][j]);
            }
        }
        int ans = 0;
        while(k>0)
        {
            ans=p.top();
            p.pop();
            k--;
        }
        return ans;
    }
};

or

(using max heap)
class Solution {
public:
    int kthSmallest(vector<vector<int>>& matrix, int k) {
        priority_queue<int>p;
        int n = matrix.size();
        int m = matrix[0].size();

        for(int i = 0; i<n; i++)
        {
            for(int j = 0; j<m; j++)
            {
               p.push(matrix[i][j]);
               if(p.size()>k)
               {
                p.pop();
               }
            }
        }
        return p.top();
    }
};
