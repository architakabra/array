ques: reverse array
ans:
#include<iostream>
using namespace std;

int main()
{
    int arr[6] = {3,1,2,4,5,6};
    int i = 0, j = 5;

    while(i <= j)
    {
        swap(arr[i], arr[j]);
        i++;
        j--;
    }

    for(int k = 0; k < 6; k++)
    {
        cout << arr[k] << " ";
    }

    return 0;
}
