ques: print odd sum and even sum of array
ans:
#include<iostream>
using namespace std;
int main()
{
    int arr[5] = {2,3,1,5,6};
    int even = 0, odd = 0;

    for(int i = 0; i<=4; i++)
    {
        if(arr[i]%2 == 0)     // even
        {
        even += arr[i];
        }
        else
        {
            odd += arr[i];
        }
    }
    cout<<even<<" "<<odd;
}
