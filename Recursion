ques: factorial
ans:
class Solution {
public:
    int factorial(int n) {
        
        // base case
        if(n == 0 || n == 1)
        {
            return 1;
        }
        
        // recursive call
        return n * factorial(n - 1);
    }
};


class Solution {
    int fact(int n) {
        //base case
        if(n == 0)
        return 1;
        
        // recursive call
        return n * fact(n - 1);
    }
    public:
    int factorial(int n)
    {
        return fact(n);
    }
};
