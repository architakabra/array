#include <iostream>
using namespace std;

void table(int n, int i)
{
    // Base case
    if(i > 10)
        return;

    cout << n << " x " << i << " = " << n * i << endl;

    // Recursive case
    table(n, i + 1);
}

int main()
{
    table(2, 1);

    return 0;
}
