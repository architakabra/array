ques: find peak element (leetcode 162)
ans:
class Solution {
public:
    int findPeakElement(vector<int>& nums) {
        int low = 0;
        int high = nums.size() - 1;

        while (low < high) {
            int mid = low + (high - low) / 2;

            // Peak is on right side
            if (nums[mid] < nums[mid + 1]) {
                low = mid + 1;
            }
            // Peak is on left side or mid itself
            else {
                high = mid;
            }
        }

        return low;
    }
};
