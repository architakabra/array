ques: first bad version (leetcode)
ans:
class Solution {
public:
    int firstBadVersion(int n) {
        long long low = 1;
        long long high = n;

        while (low < high) {
            long long mid = low + (high - low) / 2;

            if (isBadVersion(mid)) {
                high = mid; // first bad can be mid
            } else {
                low = mid + 1; // move right
            }
        }

        return low;
    }
};
