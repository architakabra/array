ans:
class Solution {
  public:

    int floorSqrt(int n) {

        int low = 1;
        int high = n;
        int ans = 0;

        while (low <= high) {

            long long mid = low + (high - low) / 2;

            // FIX: use 1LL * mid * mid
            if (1LL * mid * mid <= n) {
                ans = mid;
                low = mid + 1;
            }
            else {
                high = mid - 1;
            }
        }

        return ans;
    }
};
