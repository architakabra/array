ques: leetcode 69 square root(x)
ans:
class Solution {
public:
    int mySqrt(int x) {
        int low = 1, high = x;
        int ans = 0;

        while (low <= high) {
            long long mid = low + (high - low) / 2;

            if (mid * mid == x) {
                return mid;
            }
            else if (mid * mid > x) {
                high = mid - 1;
            }
            else {
                ans = mid;
                low = mid + 1;
            }
        }

        return ans;
    }
};
