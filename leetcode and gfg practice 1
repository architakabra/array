ques: reverse an array (gfg)
ans:
class Solution {
  public:
    void reverseArray(vector<int> &arr) {
        
        int start = 0;
        int end = arr.size() - 1;
        
        while(start < end)
        {
            swap(arr[start], arr[end]);
            
            start++;
            end--;
        }
    }
};
