ques: no. of sub arrays with odd sum (leetcode 1524)
ans:
class Solution {
public:
    int numOfSubarrays(vector<int>& arr) {
        
        int mod = 1e9 + 7;

        int odd = 0;
        int even = 1;

        int sum = 0;
        int ans = 0;

        for(int i = 0; i < arr.size(); i++)
        {
            sum += arr[i];

            // odd prefix sum
            if(sum % 2 != 0)
            {
                ans = (ans + even) % mod;
                odd++;
            }

            // even prefix sum
            else
            {
                ans = (ans + odd) % mod;
                even++;
            }
        }

        return ans;
    }
};
