ques: binary array sorting (gfg)
ans:
class Solution {
  public:
    void binSort(vector<int> &arr) {
        
        int left = 0;
        int right = arr.size() - 1;
        
        while(left < right) {
            
            // move left while element is 0
            while(arr[left] == 0 && left < right) {
                left++;
            }
            
            // move right while element is 1
            while(arr[right] == 1 && left < right) {
                right--;
            }
            
            // swap
            if(left < right) {
                swap(arr[left], arr[right]);
                left++;
                right--;
            }
        }
    }
};
