ques: chocolate distribution problem (gfg)
ans:
class Solution {
  public:
    int findMinDiff(vector<int>& a, int m) {
        
        // sort the array
        sort(a.begin(), a.end());
        
        int ans = INT_MAX;
        
        // check every window of size m
        for(int i = 0; i + m - 1 < a.size(); i++) {
            
            int diff = a[i + m - 1] - a[i];
            
            ans = min(ans, diff);
        }
        
        return ans;
    }
};
