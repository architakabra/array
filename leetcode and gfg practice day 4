ques: Kth largest element in an array (leetcode 215)
ans:
class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        
        priority_queue<int> pq;

        // push all elements into heap
        for(int i = 0; i < nums.size(); i++) {
            pq.push(nums[i]);
        }

        // remove k-1 largest elements
        for(int i = 1; i < k; i++) {
            pq.pop();
        }

        // kth largest element
        return pq.top();
    }
};
