ques: insertion sorting (leetcode 147)
ans:
class Solution {
public:
    ListNode* insertionSortList(ListNode* head) {
        
        if(head == NULL || head->next == NULL)
            return head;

        ListNode* dummy = new ListNode(0);

        ListNode* curr = head;

        while(curr != NULL) {

            ListNode* prev = dummy;

            // Find correct position
            while(prev->next != NULL && prev->next->val < curr->val) {
                prev = prev->next;
            }

            ListNode* nextNode = curr->next;

            // Insert node
            curr->next = prev->next;
            prev->next = curr;

            curr = nextNode;
        }

        return dummy->next;
    }
};
