ques: insertion sort (gfg)
ans:
class Solution {
  public:
    void insertionSort(vector<int>& arr) {
        
        int n = arr.size();
        
        for(int i = 1; i < n; i++)
        {
            int key = arr[i];
            int j = i - 1;
            
            // elements ko shift karo
            while(j >= 0 && arr[j] > key)
            {
                arr[j + 1] = arr[j];
                j--;
            }
            
            // correct position pe insert
            arr[j + 1] = key;
        }
    }
};
