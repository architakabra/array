ques: selection sort (gfg)
ans:
class Solution {
  public:
    void selectionSort(vector<int> &arr) {
        
        int n = arr.size();
        
        for(int i = 0; i < n-1; i++)
        {
            int minIndex = i;
            
            // minimum element find karo
            for(int j = i+1; j < n; j++)
            {
                if(arr[j] < arr[minIndex])
                {
                    minIndex = j;
                }
            }
            
            // swap
            swap(arr[i], arr[minIndex]);
        }
    }
};
