ques: check if array is sorted (gfg)
ans:
class Solution {
  public:
    bool isSorted(vector<int>& arr) {
        
        for(int i = 0; i < arr.size() - 1; i++) {
            
            if(arr[i] > arr[i + 1]) {
                return false;
            }
        }
        
        return true;
    }
};
