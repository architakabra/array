ques: Kadane's Algorithm (gfg)
ans:
class Solution {
  public:
    int maxSubarraySum(vector<int> &arr) {
        int maxi = INT_MIN;
        int sum = 0;

        for(int i = 0; i < arr.size(); i++) {
            sum += arr[i];

            maxi = max(maxi, sum);

            // Reset sum if it becomes negative
            if(sum < 0) {
                sum = 0;
            }
        }

        return maxi;
    }
};
