ques: two sum
ans:
class Solution{
    public:
    vector<int> twoSum(vector<int>& numbers, int target){          // vector is an integer array
        vector<int> arr;
        
        int i = 0, j = numbers.size()-1;
        while(i<=j)
        {
            if(numbers[i]+ numbers[j] == target)
            {
                arr.push_back(i+1);
                arr.push_back(j+1);
                break;
            }
            else if(numbers[i]+numbers[j] > target)
            {
                j--;
            }
            else
            {
                i++;
            }
        }
        return arr;
    }
}
