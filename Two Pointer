ques: insertion sorting
ans:
#include<iostream>
using namespace std;

//insertion sorting 
int main()
{
    int arr[5] = {5,4,3,2,1};
    int n = 5;
    
    for(int i=1; i<=n-1; i++)
    {
        for(int j=i; j>0; j--)
        {
            if(arr[j] < arr[j-1])
            {
                swap(arr[j], arr[j-1]);
            }
        }
    }
    // display sorted array
    for(int i=0; i<=n-1; i++)
    {
        cout<<arr[i]<<" ";
    }
}
