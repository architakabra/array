ques: largest no.(leetcode 179)
ans:
class Solution {
public:

    static bool cmp(string a, string b)
    {
        return a + b > b + a;
    }

    string largestNumber(vector<int>& nums) {

        vector<string> arr;

        // Convert int to string
        for(int num : nums)
        {
            arr.push_back(to_string(num));
        }

        // Sort using custom comparator
        sort(arr.begin(), arr.end(), cmp);

        // Edge case
        if(arr[0] == "0")
        {
            return "0";
        }

        string ans = "";

        // Form final answer
        for(string s : arr)
        {
            ans += s;
        }

        return ans;
    }
};
