ques: bubble sort (gfg)
ans:
class Solution {
public:
    void bubbleSort(vector<int>& arr) {
        int n = arr.size();

        for(int i = 0; i < n - 1; i++) {

            // Last i elements are already sorted
            for(int j = 0; j < n - i - 1; j++) {

                // Swap if elements are in wrong order
                if(arr[j] > arr[j + 1]) {
                    swap(arr[j], arr[j + 1]);
                }
            }
        }
    }
};
