ques: power of numbers (gfg)
ans:
class Solution {
public:
    long long mod = 1000000007;

    long long binExp(long long N, long long R) {
        if (R == 0)
            return 1;

        long long half = binExp(N, R / 2);

        if (R % 2 == 0)
            return (half * half) % mod;

        return (((half * half) % mod) * N) % mod;
    }

    long long reverseExponentiation(long long n) {
        long long r = 0, temp = n;

        while (temp > 0) {
            r = r * 10 + temp % 10;
            temp /= 10;
        }

        return binExp(n, r);
    }
};
